{
  "name": "auto-task",
  "version": "1.0.0",
  "description": "An Express application to connect to Gmail via POP and download specific emails.",
  "main": "src/app.ts",
  "scripts": {
    "start": "node --watch dist/app.js",
    "build": "tsc",
    "start:dev": "nodemon --exec ts-node src/app.ts",
    "cronjob": "ts-node src/modules/dte/cronjobs/emailFetcher.ts",
    "cronjob-dte": "ts-node src/modules/dte/cronjobs/dteSender.ts",
    "deploy": "npm run build && pm2 start ecosystem.config.js"
  },
  "dependencies": {
    "@types/imap": "^0.8.42",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.8.4",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "imap": "^0.8.19",
    "json2csv": "^6.0.0-alpha.2",
    "mailparser": "^3.7.2",
    "node-cron": "^3.0.3",
    "node-pop3": "^0.9.0",
    "nodemailer": "^6.10.0",
    "pdf-parse": "^1.1.1",
    "poplib": "^0.1.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.4.0",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.4.4"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "license": "MIT"
}
